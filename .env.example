# Example environment configuration for webrtc-camera-server.
#
# Copy to `.env` and edit. The server loads `.env` automatically at startup
# (via dotenvy); real environment variables override anything set here. All
# values are optional — with no `.env` the server runs on sensible defaults.
#
#   cp .env.example .env

# Address the HTTP/WebSocket server binds to.
# 0.0.0.0 = all interfaces (LAN-reachable); 127.0.0.1 = localhost only.
WCS_BIND=0.0.0.0

# TCP port to listen on. Must be a valid port (1-65535) or startup fails.
WCS_PORT=8090

# STUN server URI handed to each WebRTC peer for NAT traversal.
WCS_STUN=stun://stun.l.google.com:19302

# Android-emulator ICE workaround. When set to your dev box's LAN IP, ICE
# candidates containing that IP are duplicated with it rewritten to 10.0.2.2
# (the qemu host alias) so an emulator peer can reach the host. Leave UNSET /
# empty in production — it's a dev-only convenience.
# WCS_EMULATOR_LAN_IP=192.168.1.103

# Directory served as static files (the browser test client).
WCS_STATIC_DIR=templates

# Use a synthetic videotestsrc instead of a real camera (1/true/yes/on). Lets
# the server boot with no camera — e.g. in Docker on Windows/Mac, or CI. The
# device dropdown is empty in this mode. Leave unset for normal camera capture.
# WCS_TEST_SOURCE=1

# Log verbosity filter (tracing EnvFilter syntax). Logs are written as JSONL to
# logs/server.<date>.jsonl regardless of this value.
RUST_LOG=webrtc_camera_server=info,tower_http=info
